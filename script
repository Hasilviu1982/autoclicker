--[[
    Universal AutoClicker for Matcha
    - Adds a tab if UI framework is available (e.g., farm script)
    - Falls back to a floating Drawing window otherwise
    Hotkey: F2 to toggle
]]

-- ============================================================
-- 1. STATE
-- ============================================================
local ac = {
    running = false,
    clickType = "left",
    interval = 500,            -- milliseconds
    clickCount = 0,
    hotkey = 0x71,             -- F2
    clickThread = nil,
    closeRequested = false,
    sliderDragging = false,
    mode = nil,                -- "tab" or "drawing"
}

local MIN_INTERVAL = 50
local MAX_INTERVAL = 300000   -- 5 minutes
local STEP = 50

-- ============================================================
-- 2. CORE FUNCTIONS
-- ============================================================
local function performClick()
    if not ac.running then return end
    if ac.clickType == "left" then
        mouse1click()
    else
        mouse2click()
    end
    ac.clickCount = ac.clickCount + 1
end

local function toggleClicker()
    ac.running = not ac.running
    if ac.running then
        ac.clickThread = task.spawn(function()
            while ac.running do
                performClick()
                wait(ac.interval / 1000)
            end
        end)
    else
        ac.clickThread = nil
    end
end

local function resetCounter()
    ac.clickCount = 0
end

local function setInterval(val)
    val = math.floor(val / STEP) * STEP
    val = math.max(MIN_INTERVAL, math.min(MAX_INTERVAL, val))
    ac.interval = val
end

local function changeInterval(delta)
    setInterval(ac.interval + delta)
end

-- ============================================================
-- 3. TAB MODE (uses the farm UI framework)
-- ============================================================
local function renderTab()
    if type(UI) ~= "table" or type(UI.AddTab) ~= "function" then
        return false
    end

    pcall(function() UI.RemoveTab("AutoClicker") end)

    UI.AddTab("AutoClicker", function(tab)
        local main = tab:Section("AutoClicker", "Left")

        local statusText = ac.running and "Running" or "Stopped"
        main:Text("Status: " .. statusText)
        main:Text("Clicks: " .. ac.clickCount)
        main:Spacing()

        main:Text("Click Type:")
        local leftLabel = (ac.clickType == "left") and "Left (selected)" or "Left"
        local rightLabel = (ac.clickType == "right") and "Right (selected)" or "Right"
        main:Button(leftLabel, function() ac.clickType = "left" end)
        main:Button(rightLabel, function() ac.clickType = "right" end)
        main:Spacing()

        main:Text("Interval: " .. ac.interval .. " ms")
        main:Spacing()
        main:Text("Adjust interval:")
        main:Button("+ 50 ms",  function() changeInterval(50) end)
        main:Button("- 50 ms",  function() changeInterval(-50) end)
        main:Button("+ 500 ms", function() changeInterval(500) end)
        main:Button("- 500 ms", function() changeInterval(-500) end)
        main:Button("+ 5000 ms", function() changeInterval(5000) end)
        main:Button("- 5000 ms", function() changeInterval(-5000) end)
        main:Spacing()

        local toggleLabel = ac.running and "Stop" or "Start"
        main:Button(toggleLabel, function() toggleClicker() end)
        main:Button("Reset Clicks", function() resetCounter() end)
        main:Spacing()
        main:Text("Hotkey: F2")
    end)

    return true
end

local function tabLoop()
    while not ac.closeRequested do
        local ok = pcall(renderTab)
        if not ok then
            -- UI might have been destroyed; fallback to drawing mode
            ac.mode = "drawing"
            break
        end
        wait(1)
    end
end

-- ============================================================
-- 4. DRAWING MODE (floating window)
-- ============================================================
local allDrawings = {}

local function newDrawing(kind, props)
    local obj = Drawing.new(kind)
    for k, v in pairs(props) do
        obj[k] = v
    end
    obj.Visible = true
    table.insert(allDrawings, obj)
    return obj
end

