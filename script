        Size = Vector2.new(70, 28),
        Color = Color3.fromRGB(40, 40, 60),
        Filled = true,
        ZIndex = 3,
    })
    local resetBorder = newDrawing("Square", {
        Position = Vector2.new(WIN_X + 230, WIN_Y + 212),
        Size = Vector2.new(70, 28),
        Color = Color3.fromRGB(200, 200, 200),
        Filled = false,
        Transparency = 0.3,
        ZIndex = 4,
    })
    local resetText = newDrawing("Text", {
        Position = Vector2.new(WIN_X + 265, WIN_Y + 226),
        Text = "Reset",
        Color = Color3.fromRGB(255, 255, 255),
        Font = Drawing.Fonts.UI,
        FontSize = 14,
        Center = true,
        ZIndex = 5,
    })
    local hotkeyLabel = newDrawing("Text", {
        Position = Vector2.new(WIN_X + 20, WIN_Y + 260),
        Text = "Hotkey: F2",
        Color = Color3.fromRGB(150, 150, 150),
        Font = Drawing.Fonts.UI,
        FontSize = 12,
        Center = false,
        ZIndex = 5,
    })

    -- Update functions for drawing mode
    local function updateStatus(running)
        if running then
            statusLabel.Text = "Status: Running"
            statusLabel.Color = Color3.fromRGB(100, 255, 100)
            toggleText.Text = "Stop"
            toggleBg.Color = Color3.fromRGB(200, 50, 50)
        else
            statusLabel.Text = "Status: Stopped"
            statusLabel.Color = Color3.fromRGB(255, 100, 100)
            toggleText.Text = "Start"
            toggleBg.Color = Color3.fromRGB(50, 200, 50)
        end
    end

    local function updateCount()
        countLabel.Text = "Clicks: " .. ac.clickCount
    end

    local function updateIntervalDisplay(val)
        intervalValue.Text = tostring(val)
    end

    local function updateSliderPosition(val)
        local pos = (val - MIN_INTERVAL) / (MAX_INTERVAL - MIN_INTERVAL)
        sliderHandle.Position = Vector2.new(SLIDER_X + pos * SLIDER_W, SLIDER_Y + SLIDER_H/2)
    end

    -- Override setInterval to update drawing
    local oldSetInterval = setInterval
    setInterval = function(val)
        oldSetInterval(val)
        updateIntervalDisplay(ac.interval)
        updateSliderPosition(ac.interval)
    end

    -- Override toggle and reset to update drawing
    local oldToggle = toggleClicker
    toggleClicker = function()
        oldToggle()
        updateStatus(ac.running)
        updateCount()
    end

    local oldReset = resetCounter
    resetCounter = function()
        oldReset()
        updateCount()
    end

    -- Initial update
    updateStatus(ac.running)
    updateCount()
    updateIntervalDisplay(ac.interval)
    updateSliderPosition(ac.interval)

    -- Polling loop for drawing mode
    local function pollEvents()
        local Players = game:GetService("Players")
        local LocalPlayer = Players.LocalPlayer
        local Mouse = LocalPlayer:GetMouse()

        while not ac.closeRequested do
            local mx, my = Mouse.X, Mouse.Y
            local leftPressed = ismouse1pressed and ismouse1pressed() or false

            if ac.sliderDragging then
                local relX = mx - SLIDER_X
                relX = math.max(0, math.min(relX, SLIDER_W))
                local val = MIN_INTERVAL + (relX / SLIDER_W) * (MAX_INTERVAL - MIN_INTERVAL)
                setInterval(val)
                if not leftPressed then
                    ac.sliderDragging = false
                end
            end

            if leftPressed and not ac.sliderDragging then
                -- Close
                if mx >= closeBg.Position.X and mx <= closeBg.Position.X + 20 and
                   my >= closeBg.Position.Y and my <= closeBg.Position.Y + 20 then
                    ac.closeRequested = true
                    break
                end

                -- Toggle
                if mx >= toggleBg.Position.X and mx <= toggleBg.Position.X + 110 and
                   my >= toggleBg.Position.Y and my <= toggleBg.Position.Y + 35 then
                    toggleClicker()
                    while ismouse1pressed and ismouse1pressed() do wait(0.02) end
                end

                -- Left type
                if mx >= leftBg.Position.X and mx <= leftBg.Position.X + 70 and
                   my >= leftBg.Position.Y and my <= leftBg.Position.Y + 26 then
                    ac.clickType = "left"
                    leftBg.Color = Color3.fromRGB(70, 130, 255)
                    rightBg.Color = Color3.fromRGB(60, 60, 80)
                    while ismouse1pressed and ismouse1pressed() do wait(0.02) end
                end

                -- Right type
                if mx >= rightBg.Position.X and mx <= rightBg.Position.X + 70 and
                   my >= rightBg.Position.Y and my <= rightBg.Position.Y + 26 then
                    ac.clickType = "right"
                    rightBg.Color = Color3.fromRGB(70, 130, 255)
                    leftBg.Color = Color3.fromRGB(60, 60, 80)
                    while ismouse1pressed and ismouse1pressed() do wait(0.02) end
                end

                -- Reset
                if mx >= resetBg.Position.X and mx <= resetBg.Position.X + 70 and
                   my >= resetBg.Position.Y and my <= resetBg.Position.Y + 28 then
                    resetCounter()
                    while ismouse1pressed and ismouse1pressed() do wait(0.02) end
                end

                -- Slider handle
                local hx = sliderHandle.Position.X
                local hy = sliderHandle.Position.Y
                if math.abs(mx - hx) <= handleRadius and math.abs(my - hy) <= handleRadius then
                    ac.sliderDragging = true
                end
            end

            -- Hotkey F2
            if iskeypressed and iskeypressed(ac.hotkey) then
                toggleClicker()
                while iskeypressed and iskeypressed(ac.hotkey) do wait(0.02) end
            end

            wait(0.02)
        end

        -- Cleanup drawings
        for _, obj in ipairs(allDrawings) do
            pcall(function() obj:Remove() end)
        end
    end

    -- Start polling in drawing mode
    task.spawn(pollEvents)
end

-- ============================================================
-- 5. MAIN ENTRY POINT
-- ============================================================
-- Determine mode: if UI framework exists, use tab; otherwise drawing
local function start()
    -- Check if we have the UI framework
    local hasUI = type(UI) == "table" and type(UI.AddTab) == "function"

    if hasUI then
        ac.mode = "tab"
        print("AutoClicker: Tab mode (UI framework detected)")
        tabLoop()  -- this runs until UI is destroyed or we switch
        -- If tabLoop exits because UI was destroyed, fallback to drawing
        if not ac.closeRequested then
            ac.mode = "drawing"
            print("AutoClicker: Falling back to drawing mode")
            createDrawingGUI()
        end
    else
        ac.mode = "drawing"
        print("AutoClicker: Standalone drawing mode")
        createDrawingGUI()
    end
end

-- Start the script
start()
