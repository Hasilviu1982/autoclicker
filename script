    local handleX = SLIDER_X + (ac.interval - MIN_INTERVAL) / (MAX_INTERVAL - MIN_INTERVAL) * SLIDER_W
    local sliderHandle = newDrawing("Circle", {
        Position = Vector2.new(handleX, SLIDER_Y + SLIDER_H/2),
        Radius = handleRadius,
